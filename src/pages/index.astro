---
import ImageDeliveryShowcase from "~/components/ImageDeliveryShowcase.astro";

const ORIGIN = "https://cf-images-demo-r2.jgerard.dev";
const SOURCE_IMAGE = ORIGIN + "/sunlight-dark-castle.png";

// Cloudflare Images URL transformations docs: https://developers.cloudflare.com/images/transform-images/transform-via-url/
const buildImageUrl = (width: number) =>
  `${ORIGIN}/cdn-cgi/image/f=auto,fit=cover,w=${width}/${SOURCE_IMAGE}`;

const widths = [480, 768, 1024, 1440, 2048];
const src = buildImageUrl(2048);
const srcset = widths
  .map((width) => `${buildImageUrl(width)} ${width}w`)
  .join(", ");
---

<ImageDeliveryShowcase>
  <img
    alt="A dark stone castle lit by low sunlight through misty hills."
    class="aspect-square size-full object-cover"
    decoding="async"
    fetchpriority="high"
    loading="eager"
    sizes="(min-width: 1024px) 50vw, 100vw"
    src={src}
    srcset={srcset}
    width="2048"
    height="2048"
  />
</ImageDeliveryShowcase>
