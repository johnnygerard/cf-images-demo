---
import ImageDeliveryStats from "~/components/ImageDeliveryStats.astro";
import Layout from "~/layouts/Layout.astro";

const ORIGIN = "https://cf-images-demo-r2.jgerard.dev";
const SOURCE_IMAGE = ORIGIN + "/sunlight-dark-castle.png";

// Cloudflare Images URL transformations docs: https://developers.cloudflare.com/images/transform-images/transform-via-url/
const buildImageUrl = (width: number) =>
  `${ORIGIN}/cdn-cgi/image/f=auto,fit=cover,w=${width}/${SOURCE_IMAGE}`;

const widths = [480, 768, 1024, 1440, 2048];
const src = buildImageUrl(2048);
const srcset = widths
  .map((width) => `${buildImageUrl(width)} ${width}w`)
  .join(", ");

const imageStats = [
  { label: "Format", value: "Auto" },
  { label: "Quality", value: "85 (default)" },
  { label: "Srcset", value: "5 breakpoints" },
];
---

<Layout title="Cloudflare Images Demo">
  <section
    class="mx-auto w-full max-w-6xl px-6 py-12 sm:px-8 sm:py-16 lg:px-10"
  >
    <div
      class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16"
    >
      <div class="space-y-6">
        <p
          class="text-xs font-medium tracking-[0.3em] text-neutral-400 uppercase"
        >
          Cloudflare Images
        </p>
        <div class="space-y-4">
          <h1
            class="text-4xl font-semibold text-balance text-white sm:text-5xl"
          >
            Responsive image delivery from Cloudflare’s edge.
          </h1>
          <p class="max-w-2xl text-base leading-7 text-neutral-300 sm:text-lg">
            This hero image is delivered through Cloudflare Images using
            responsive widths, automatic format negotiation, and edge
            optimization for faster loads.
          </p>
        </div>

        <ImageDeliveryStats items={imageStats} />
      </div>

      <figure
        class="overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-900/70 shadow-2xl shadow-black/30"
      >
        <img
          alt="A dark stone castle lit by low sunlight through misty hills."
          class="aspect-square size-full object-cover"
          decoding="async"
          fetchpriority="high"
          loading="eager"
          sizes="(min-width: 1024px) 50vw, 100vw"
          src={src}
          srcset={srcset}
          width="2048"
          height="2048"
        />
      </figure>
    </div>
  </section>
</Layout>
