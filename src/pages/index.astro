---
import { Image } from "astro:assets";
import ImageDeliveryStats from "~/components/ImageDeliveryStats.astro";
import Layout from "~/layouts/Layout.astro";
import { tw } from "~/utils/tw";

export const prerender = false;
---

<Layout
  title="Cloudflare Images Demo"
  description="Demo of responsive image delivery with Astro 6, Cloudflare Images, and edge optimization on Cloudflare Workers."
>
  <section
    class="mx-auto w-full max-w-6xl px-6 py-12 sm:px-8 sm:py-16 lg:px-10"
  >
    <div
      class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16"
    >
      <div class="space-y-6">
        <p
          class="text-xs font-medium tracking-[0.3em] text-neutral-400 uppercase"
        >
          Cloudflare Images
        </p>
        <div class="space-y-4">
          <h1
            class="text-4xl font-semibold text-balance text-white sm:text-5xl"
          >
            Responsive image delivery from Cloudflare’s edge.
          </h1>
          <p
            class="max-w-2xl text-base leading-7 text-pretty text-neutral-300 sm:text-lg"
          >
            The current page uses on-demand rendering and the Astro Image
            component to serve optimized image variants from a source image
            stored in Cloudflare R2.
          </p>
        </div>

        <ImageDeliveryStats
          items={[
            { label: "Output format", value: "AVIF" },
            { label: "Original resolution", value: "2048x2048" },
            { label: "Srcset attribute", value: "5 breakpoints" },
          ]}
        />
      </div>

      <Image
        alt="A dark stone castle lit by low sunlight through misty hills."
        class={tw(
          "aspect-square w-full rounded-3xl border border-neutral-800",
          "bg-neutral-900/70 shadow-2xl shadow-black/30",
        )}
        format="avif"
        width={2048}
        height={2048}
        priority
        sizes="(min-width: 64rem) 36rem, 100vw"
        src="https://cf-images-demo-r2.jgerard.dev/sunlight-dark-castle.png"
        widths={[480, 768, 1024, 1440, 2048]}
      />
    </div>
  </section>
</Layout>
